{% doc %}
  @prompt
    Create a testimonial section with customer reviews and ratings
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-testimonials-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-testimonials-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-testimonials-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: 40px;
  }

  .ai-testimonials-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
    font-weight: 600;
  }

  .ai-testimonials-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-testimonials-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-testimonial-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    padding: {{ block.settings.card_padding }}px;
    border-radius: {{ block.settings.card_border_radius }}px;
    border: {{ block.settings.card_border_thickness }}px solid {{ block.settings.card_border_color }};
    box-shadow: 0 {{ block.settings.card_shadow_vertical }}px {{ block.settings.card_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity | divided_by: 100.0 }});
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-testimonial-rating-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
    align-items: center;
  }

  .ai-testimonial-star-{{ ai_gen_id }} {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    fill: {{ block.settings.star_color }};
  }

  .ai-testimonial-star-empty-{{ ai_gen_id }} {
    fill: {{ block.settings.star_empty_color }};
  }

  .ai-testimonial-review-{{ ai_gen_id }} {
    font-size: {{ block.settings.review_text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-testimonial-author-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: auto;
  }

  .ai-testimonial-avatar-{{ ai_gen_id }} {
    width: {{ block.settings.avatar_size }}px;
    height: {{ block.settings.avatar_size }}px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .ai-testimonial-avatar-placeholder-{{ ai_gen_id }} {
    width: {{ block.settings.avatar_size }}px;
    height: {{ block.settings.avatar_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.card_border_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ai-testimonial-avatar-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    fill: {{ block.settings.text_color }};
    opacity: 0.3;
  }

  .ai-testimonial-author-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .ai-testimonial-author-name-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    color: {{ block.settings.heading_color }};
    margin: 0;
  }

  .ai-testimonial-author-title-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-testimonials-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-testimonials-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-testimonials-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-testimonials-subtitle-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.9);
    }
  }
{% endstyle %}

<testimonials-section-{{ ai_gen_id }} class="ai-testimonials-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-testimonials-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-testimonials-header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-testimonials-title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <div class="ai-testimonials-subtitle-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-testimonials-grid-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign review_key = 'review_' | append: i
          assign rating_key = 'rating_' | append: i
          assign name_key = 'customer_name_' | append: i
          assign title_key = 'customer_title_' | append: i
          assign avatar_key = 'customer_avatar_' | append: i

          assign review = block.settings[review_key]
          assign rating = block.settings[rating_key]
          assign name = block.settings[name_key]
          assign title = block.settings[title_key]
          assign avatar = block.settings[avatar_key]
        %}

        {% if review != blank %}
          <div class="ai-testimonial-card-{{ ai_gen_id }}">
            <div class="ai-testimonial-rating-{{ ai_gen_id }}">
              {% for star in (1..5) %}
                <svg class="ai-testimonial-star-{{ ai_gen_id }} {% if star > rating %}ai-testimonial-star-empty-{{ ai_gen_id }}{% endif %}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              {% endfor %}
            </div>

            <div class="ai-testimonial-review-{{ ai_gen_id }}">{{ review }}</div>

            <div class="ai-testimonial-author-{{ ai_gen_id }}">
              {% if avatar != blank %}
                <img
                  src="{{ avatar | image_url: width: 100 }}"
                  alt="{{ name | escape }}"
                  class="ai-testimonial-avatar-{{ ai_gen_id }}"
                  width="100"
                  height="100"
                  loading="lazy"
                >
              {% else %}
                <div class="ai-testimonial-avatar-placeholder-{{ ai_gen_id }}">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                    <circle cx="12" cy="7" r="4"></circle>
                  </svg>
                </div>
              {% endif %}

              <div class="ai-testimonial-author-info-{{ ai_gen_id }}">
                {% if name != blank %}
                  <p class="ai-testimonial-author-name-{{ ai_gen_id }}">{{ name }}</p>
                {% endif %}
                {% if title != blank %}
                  <p class="ai-testimonial-author-title-{{ ai_gen_id }}">{{ title }}</p>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</testimonials-section-{{ ai_gen_id }}>

<script>
  (function() {
    class TestimonialsSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('testimonials-section-{{ ai_gen_id }}', TestimonialsSection{{ ai_gen_id }});
  })();
</script>

