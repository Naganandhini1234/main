{% capture slick_prev_arrow %}
  <button type="button" class="button button--secondary slick-prevs" is="previous-button" aria-controls="Slider-{{ section_id }}" aria-label="{{ 'general.pagination.previous' | t | escape }}">
    <span class="btn-fill" data-fill></span>
    <span class="btn-text">{%- render 'icon', icon: 'chevron-left', class: 'transform' -%}</span>
  </button>
{% endcapture %}

{% capture slick_next_arrow %}
  <button type="button" class="button button--secondary slick-nexts" is="next-button" aria-controls="Slider-{{ section_id }}" aria-label="{{ 'general.pagination.next' | t | escape }}">
    <span class="btn-fill" data-fill></span>
    <span class="btn-text">{%- render 'icon', icon: 'chevron-right', class: 'transform' -%}</span>
  </button>
{% endcapture %}

<!-- MODAL 1: Scent Selection -->
<div class="myop-modal first-myop-modal" id="myop-modal-{{ section_id }}">
  <div class="myop-modal-backdrop"></div>
  <div class="myop-modal-content">
    <div class="myop-modal-body">
      <div class="myop-modal-list">
        {% if scent_collection != blank %}
          {% for product in scent_collection.products %}
            {% assign target_variant = nil %}
            {% for variant in product.variants %}
              {% if variant.title == '100ml Personalized' %}
                {% assign target_variant = variant %}
                {% break %}
              {% endif %}
            {% endfor %}
            {% if target_variant != nil and target_variant.available %}
              <div
                class="myop-scent-card"
                data-banner-img="{{ product.metafields.custom.personalize_banner_image | image_url: width: 1600 | default: '' }}"
                data-top-notes="{{ product.metafields.custom.top_notes_image | image_url: width: 500 | default: '' }}"
                data-middle-notes="{{ product.metafields.custom.middle_notes_image | image_url: width: 500 | default: '' }}"
                data-base-notes="{{ product.metafields.custom.base_notes_image | image_url: width: 500 | default: '' }}"
                data-intensity-img="{{ product.metafields.custom.intensity_dropdown | image_url: width: 800 | default: '' }}"
                data-personality-img="{{ product.metafields.custom.personality_dropdown | image_url: width: 800 | default: '' }}"
                data-product-id="{{ product.id }}"
                data-variant-id="{{ target_variant.id }}"
                data-title="{{ product.title | escape }}"
                data-price="{{ target_variant.price | money_without_currency }}"
                {% if product.featured_image %} data-image="{{ product.featured_image | image_url: width: 800 }}" {% endif %}
              >
                {% if product.featured_image %}
                  {{ product.featured_image | image_url: width: 800 | image_tag: alt: product.title, class: 'myop-scent-img' }}
                {% endif %}
                <div class="myop-scent-card-title">{{ product.title }}</div>
              </div>
            {% endif %}
          {% endfor %}
        {% endif %}
      </div>
    </div>
    <div class="myop-modal-footer">
      <button type="button" class="myop-modal-cancel">Cancel</button>
      <button type="button" class="myop-modal-apply button button--primary button--fixed" disabled>
        <span class="btn-fill" data-fill=""></span>
        <span class="btn-text">Apply</span>
      </button>
    </div>
  </div>
</div>

<!-- MODAL 2: Scent Details -->
<div class="myop-modal" id="myop-detail-modal" aria-hidden="true">
  <div class="myop-modal-backdrop"></div>
  <div class="myop-modal-content myop-modal-second-content">
    <div class="myop-detail-banner">
      <img id="myop-detail-banner-img" src="" alt="" loading="lazy">
    </div>
    <div class="myop-detail-header">
      <h3 class="myop-detail-title"></h3>
      <span class="myop-detail-volume">(100ml)</span>
      <span class="myop-detail-price"></span>
    </div>
    <div class="myop-detail-content">
      <div class="myop-detail-track"><!-- JS injects slides here --></div>
    </div>
    <div class="myop-modal-footer">
      <button type="button" class="myop-detail-back">Cancel</button>
      <button type="button" class="myop-modal-apply button button--primary button--fixed" is="hover-button" disabled>
        <span class="btn-fill" data-fill=""></span>
        <span class="btn-text">Apply</span>
      </button>
    </div>
  </div>
</div>

<script>
  window.MYOP_SLICK_CONFIG = {
    prev: {{ slick_prev_arrow | json }},
    next: {{ slick_next_arrow | json }}
  };
</script>