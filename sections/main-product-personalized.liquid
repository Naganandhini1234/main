<!--nv !-->
{%- assign myop_block = section.blocks | where: 'type', 'myop_step1' | first -%}
{%- assign scent_collection = myop_block.settings.scent_collection -%}
{% assign first_image = product.selected_or_first_available_variant.featured_image | default: product.images.first %}

<link rel="stylesheet" href="{{ 'product-customization.css' | asset_url }}">

<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media screen and (min-width: 1024px) {
    #shopify-section-{{ section.id }} {
      {%- assign media_ratio = section.settings.media_size | divided_by: 50.0 -%}
      --product-grid: auto / minmax(0, {{ media_ratio }}fr) minmax(0, {{ 2.0 | minus: media_ratio }}fr);
    }
  }

  {%- assign first_media = product.selected_or_first_available_variant.featured_media | default: product.media.first -%}

  {%- if section.settings.image_ratio_mobile == 'adapt_first' -%}
    @media screen and (max-width: 767px) {
      #SliderGallery-{{ section.id }} .mobile\:media--adapt_first>:is(img, svg, video-media) {
        aspect-ratio: {{ first_media.aspect_ratio }};
      }
    }
  {%- endif -%}

  {%- if section.settings.gallery_layout == 'thumbnail' and section.settings.image_ratio == 'adapt_first' -%}
    @media screen and (min-width: 768px) {
      #SliderGallery-{{ section.id }} .media--adapt_first>:is(img, svg, video-media) {
        aspect-ratio: {{ first_media.aspect_ratio }};
      }
    }
  {%- endif -%}
</style>

{%- liquid
  assign product_form_id = 'ProductForm-' | append: section.id
  assign media_count = product.media.size
  assign first_3d_model = product.media | where: 'media_type', 'model' | first
-%}

{%- if first_3d_model -%}
  {{ 'model-viewer.css' | asset_url | stylesheet_tag }}
  <link id="ModelViewerStyle" rel="stylesheet" href="https://cdn.shopify.com/shopifycloud/model-viewer-ui/assets/v1.0/model-viewer-ui.css" media="print" onload="this.media='all'">
  <link id="ModelViewerOverride" rel="stylesheet" href="{{ 'model-viewer-ui.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

<div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}">
  <div class="page-width{% if media_count > 0 %}{% if section.settings.full_width %} page-width--full{% endif %}{% else %} page-width--narrow{% endif %} relative">
    <div class="featured-product product product--{{ section.settings.gallery_layout }}{% if media_count == 0 %} no-media{% endif %} flex flex-col items-start lg:grid gap-5 w-full relative">
      
      {%- if media_count > 0 -%}
        {% if product.template_suffix == 'personalizedproductpage' %}
          <canvas id="myop-canvas-pdp" style="display:none;"></canvas>
        {% endif %}
        
        {%- render 'product-media-gallery',
          product: product,
          section_id: section.id,
          gallery_layout: section.settings.gallery_layout,
          thumbnail_position: section.settings.thumbnail_position,
          image_ratio: section.settings.image_ratio,
          image_ratio_mobile: section.settings.image_ratio_mobile,
          image_zoom: section.settings.image_zoom,
          mobile_layout: section.settings.mobile_layout,
          mobile_thumbnail: section.settings.mobile_thumbnail,
          hide_variants: section.settings.hide_variants,
          enable_video_autoplay: section.settings.enable_video_autoplay,
          enable_video_looping: section.settings.enable_video_looping,
          product_form_id: product_form_id
        -%}
      {%- endif -%}

      <animate-element
        class="product__info block{% if section.settings.enable_sticky_info %} sticky{% endif %} w-full"
        data-animate="fade-up"
        data-immediate
      >
        {%- liquid
          assign title_block = section.blocks | where: 'type', 'title' | first
          assign title_block_show_price = false
          if title_block.settings.show_price == true
            assign title_block_show_price = true
          endif
          assign title_block_show_rating = false
          if title_block.settings.show_rating == true
            assign title_block_show_rating = true
          endif
        -%}

        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when '@app' -%}
              {%- render block -%}

            {%- when 'myop_trust_icons' -%}
              {%- render 'product-myop-trust-icons', block: block -%}

            {%- when 'myop_gift_options' -%}
              {%- render 'product-myop-gift-options', block: block, product: product -%}

            {%- when 'myop_step1' -%}
              {%- render 'product-myop-step1', block: block, scent_collection: scent_collection, section_id: section.id -%}

            {%- when 'myop_step2' -%}
              {%- render 'product-myop-step2', block: block, section_id: section.id -%}

            {%- when 'title' -%}
              <div class="product__title{% if block.settings.show_price %} with-price{% endif %}" {{ block.shopify_attributes }}>
                <h1 class="leading-none font-bold {{ block.settings.title_size }} mobile:{{ block.settings.title_size_mobile }} col-span-full">
                  <split-words class="split-words flex flex-wrap" data-animate="fade-up">
                    {{- product.title -}}
                  </split-words>
                </h1>
                
                {%- if product.template_suffix == 'personalizedproductpage' -%}
                  <div id="Price-{{ section.id }}" class="product__price myop-hidden">
                    {%- render 'product-price', product: product, use_variant: true -%}
                  </div>
                {%- else -%}
                  {%- if block.settings.show_price -%}
                    <div id="Price-{{ section.id }}" class="product__price">
                      {%- render 'product-price',
                        product: product,
                        use_variant: true,
                        class: 'flex flex-wrap items-baseline gap-2 lg:flex-col xl:items-end lg:gap-1d5'
                      -%}
                    </div>
                  {%- endif -%}
                {%- endif -%}

                {%- liquid
                  if block.settings.show_rating
                    render 'product-rating', product: product
                  endif
                -%}
              </div>
              {% render 'live-visitors' %}
              {%- if block.settings.show_price -%}
                {%- assign product_form_installment_id = 'ProductFormInstallment-' | append: section.id -%}
                {%- form 'product', product, id: product_form_installment_id, class: 'installment text-sm leading-tight' -%}
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                  {{ form | payment_terms }}
                {%- endform -%}
              {%- endif -%}

            {%- when 'buy_buttons' -%}
              {% if product.template_suffix == 'personalizedproductpage' %}
                <div class="myop-buttons add-to-cart-close" {{ block.shopify_attributes }}>
                  {%- render 'buy-buttons',
                    block: block,
                    product: product,
                    product_form_id: product_form_id,
                    section_id: section.id,
                    disableButton: true,
                    type: "customized-pop-up"
                  -%}
                </div>
              {% else %}
                {%- render 'buy-buttons',
                  block: block,
                  product: product,
                  product_form_id: product_form_id,
                  section_id: section.id
                -%}
              {% endif %}

            {%- else -%}
              {%- comment -%}
              All other block types (breadcrumb, text, price, sku, etc.) 
              render as normal from the main product section
              {%- endcomment -%}
          {%- endcase -%}
        {%- endfor -%}
      </animate-element>
    </div>

    {%- assign sticky_buy_button = section.blocks | where: 'type', 'sticky_buy_button' | first -%}
    {%- if product.available and sticky_buy_button -%}
      {%- render 'product-sticky-buy-button', 
        product: product, 
        section_id: section.id, 
        product_form_id: product_form_id 
      -%}
    {%- endif -%}
  </div>

  {%- render 'product-myop-modals', section_id: section.id, scent_collection: scent_collection -%}

  {%- render 'product-schema', product: product, section_id: section.id -%}

  {%- render 'product-popup', block: block, product: product, product_form_id: product_form_id, section_id: section.id -%}
</div>

<script src="{{ 'product-customization.js' | asset_url }}" defer></script>
<script>
  // Initialize with Liquid variables
  window.MYOP_CONFIG = {
    sectionId: '{{ section.id }}',
    enableSillageImage: {{ section.settings.enable_sillage_image | json }},
    enableScentDetails: {{ section.settings.enable_scent_details | json }},
    firstImageUrl: "{{ first_image | image_url: width: 900 }}"
  };
</script>

{% schema %}
{
  "name": "Product - Personalized",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_sticky_info",
      "default": true,
      "label": "Enable sticky product info"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 72
    },
    {
      "type": "checkbox",
      "id": "enable_sillage_image",
      "label": "Enable Sillage Image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_scent_details",
      "label": "Enable Intensity / Notes / Personality",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "myop_trust_icons",
      "name": "Trust / Info Icons",
      "settings": [
        {
          "type": "checkbox",
          "id": "enable",
          "label": "Enable trust icons",
          "default": true
        },
        {
          "type": "image_picker",
          "id": "icon_1",
          "label": "Icon 1"
        },
        {
          "type": "text",
          "id": "text_1",
          "label": "Text 1",
          "default": "Chosen by 10,000+ customers for gifting"
        },
        {
          "type": "image_picker",
          "id": "icon_2",
          "label": "Icon 2"
        },
        {
          "type": "text",
          "id": "text_2",
          "label": "Text 2",
          "default": "Ships within 24–48 hours"
        },
        {
          "type": "image_picker",
          "id": "icon_3",
          "label": "Icon 3"
        },
        {
          "type": "text",
          "id": "text_3",
          "label": "Text 3",
          "default": "Easy EMI available"
        }
      ]
    },
    {
      "type": "myop_gift_options",
      "name": "Gift Options",
      "settings": [
        {
          "type": "checkbox",
          "id": "enable_gift_wrap",
          "label": "Enable Free Gift Wrap",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "enable_personal_note",
          "label": "Enable Personal Note",
          "default": true
        }
      ]
    },
    {
      "type": "myop_step1",
      "name": "Choose Perfume",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "enable",
          "label": "Enable Step 1",
          "default": true
        },
        {
          "type": "collection",
          "id": "scent_collection",
          "label": "Perfume collection"
        }
      ]
    },
    {
      "type": "myop_step2",
      "name": "Engraving & Font",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "enable",
          "label": "Enable Step 2",
          "default": true
        },
        {
          "type": "text",
          "id": "text_placeholder",
          "label": "Text placeholder",
          "default": "Write your text here..."
        }
      ]
    },
    {
      "type": "title",
      "name": "Title"
    },
    {
      "type": "buy_buttons",
      "name": "Buy buttons"
    }
  ]
}
{% endschema %}